# --- قاعدة البيانات (PostgreSQL) ---
# استخدم رابط قاعدة بيانات PostgreSQL محلية أو سحابية
# يمكنك الحصول على قاعدة بيانات مجانية من:
# - Neon (neon.tech) - مجاني
# - Supabase (supabase.com) - مجاني
# - Railway (railway.app) - مجاني مع باقة التجربة
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/app_db"

# --- رابط الموقع العام (للإشعارات والروابط) ---
# اتركه فارغاً إذا كنت تعمل محلياً
# ضع رابط الموقع بعد النشر مثلاً:
NEXT_PUBLIC_BASE_URL="https://maaref-haithem.vercel.app"

# --- Twilio WhatsApp API (لإرسال التذكيرات) ---
# أنشئ حساب على twilio.com وافعل WhatsApp Sandbox
# TWILIO_ACCOUNT_SID="your_account_sid"
# TWILIO_AUTH_TOKEN="your_auth_token"
# TWILIO_WHATSAPP_NUMBER="+14155238886"

# --- Cron Job Secret Key (للتذكير التلقائي) ---
# استخدم هذا المفتاح لحماية مسار cron-job
# CRON_SECRET="maaref-cron-2024"

# --- Google Sheets API (اختياري - بديل عن PostgreSQL) ---
# استخدم Google Sheets كقاعدة بيانات بدلاً من PostgreSQL
# اتركه فارغاً لاستخدام PostgreSQL العادي
NEXT_PUBLIC_GSHEET_API_URL="https://script.google.com/macros/s/AKfycbxjMiWT4yVCQ3BwVcePyK-TtQM2K_Bf54ZagNMVPq4ysJW9UJgyjjjaQVfa-NUYOtqb/exec"

# --- (اختياري) SMTP للبريد الإلكتروني ---
# لإرسال إشعارات للمرضى عند إضافة نتائج جديدة
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"
